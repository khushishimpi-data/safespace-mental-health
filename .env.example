# SafeSpace Environment Configuration
# Copy this file to .env and fill in your actual values

# ==================== APPLICATION ====================
ENVIRONMENT=development
DEBUG=True
SECRET_KEY=your-secret-key-change-this-in-production-use-uuid

# ==================== DATABASE ====================
# PostgreSQL
DATABASE_URL=postgresql://safespace:safespace@localhost:5432/safespace

# MongoDB (optional, for conversation storage)
MONGODB_URL=mongodb://localhost:27017/safespace

# ==================== LLM & AI SERVICES ====================
# Select provider: openai, groq, or medgemma
LLM_PROVIDER=openai
LLM_MODEL=gpt-4-turbo
TEMPERATURE=0.7

# OpenAI
OPENAI_API_KEY=sk-your-api-key-here

# Groq (faster, free tier available)
GROQ_API_KEY=gsk-your-key-here

# Google Cloud (for MedGemma and Speech)
GOOGLE_API_KEY=your-google-cloud-key
GOOGLE_CLOUD_SPEECH_CREDENTIALS=/path/to/credentials.json

# Local LLM (Ollama)
USE_LOCAL_LLM=False
OLLAMA_BASE_URL=http://localhost:11434
MEDGEMMA_MODEL=medgemma-2b

# ==================== VOICE SERVICES ====================
# Provider: google, azure, or local
VOICE_PROVIDER=local

# Azure Cognitive Services
AZURE_SPEECH_KEY=your-azure-key
AZURE_SPEECH_REGION=eastus

# ==================== EMERGENCY SERVICES ====================
# Twilio (for emergency calls)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890
EMERGENCY_CONTACT_NUMBER=+1234567890

# ==================== LOCATION SERVICES ====================
GOOGLE_MAPS_API_KEY=your-maps-api-key
ENABLE_LOCATION_SERVICES=True

# ==================== EMAIL CONFIGURATION ====================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=support@safespace.ai

# ==================== LOGGING ====================
LOG_LEVEL=INFO
LOG_FILE=logs/safespace.log

# ==================== FEATURE FLAGS ====================
ENABLE_SCREENING=True
ENABLE_VOICE_INPUT=True
ENABLE_GAMIFICATION=True
ENABLE_EMERGENCY_RESPONSE=True
ENABLE_LOCATION_MATCHING=True

# ==================== SECURITY ====================
# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8501,http://localhost:8000

# ==================== DEPLOYMENT ====================
# For production, use appropriate values
APP_NAME=SafeSpace - AI Mental Health Therapist
APP_VERSION=1.0.0

# API Documentation
API_DOCS_URL=/docs
OPENAPI_URL=/openapi.json
